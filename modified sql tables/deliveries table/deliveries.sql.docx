
-- 2.deliveries table
show create table deliveries;

alter table deliveries
rename column match_no to match_id;


alter table deliveries
add constraint Fk_match_id
foreign key(match_id)
references matches(match_id);

alter table deliveries
add column ball_id int auto_increment primary key not null First;

update deliveries
set date = str_to_date(date,'%M %d,%Y');
alter table deliveries
modify date DATE;

UPDATE deliveries
SET player_dismissed = NULL
WHERE player_dismissed = '';

UPDATE deliveries
SET wicket_type = NULL
WHERE wicket_type = '';

select * from deliveries;







